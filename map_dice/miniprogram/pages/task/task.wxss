.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1a1a2e;
}

.header {
  padding: 20px;
  background: linear-gradient(180deg, #1a2744 0%, #0d1929 100%);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.title {
  font-size: 18px;
  color: #fff;
  font-weight: 600;
  display: block;
}

.subtitle {
  font-size: 13px;
  color: #1dd1a1;
  margin-top: 8px;
  display: block;
  word-break: break-all;
}

.scroll-body {
  flex: 1;
  height: 0;
}

.section {
  padding: 16px 20px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.section-title {
  font-size: 15px;
  color: #1dd1a1;
  font-weight: 600;
  display: block;
  margin-bottom: 12px;
}

.theme {
  font-size: 14px;
  color: #ccc;
  line-height: 1.6;
}

.list {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.list .num {
  flex-shrink: 0;
  color: #8a9eba;
  font-size: 14px;
}

.list .bullet {
  flex-shrink: 0;
  color: #8a9eba;
  font-size: 14px;
}

.list .item {
  font-size: 14px;
  color: #ccc;
  line-height: 1.6;
  flex: 1;
}

.item.block {
  display: block;
  font-size: 14px;
  color: #ccc;
  line-height: 1.6;
}

.tool-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

.tool-row text {
  font-size: 14px;
  color: #8a9eba;
}

.tool-input {
  width: 80px;
  padding: 8px 12px;
  background: rgba(26, 26, 46, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  color: #eee;
  font-size: 14px;
}

.tool-result {
  font-size: 16px;
  color: #1dd1a1;
  font-weight: 600;
}

.footer {
  padding: 16px 20px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.btn-copy {
  width: 100%;
  padding: 14px 24px;
  font-size: 16px;
  border-radius: 12px;
  border: none;
  background: linear-gradient(135deg, #1dd1a1, #0f9b8e);
  color: #fff;
}

.empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  color: #8a9eba;
}

.empty .link {
  margin-top: 20px;
  color: #1dd1a1;
}
