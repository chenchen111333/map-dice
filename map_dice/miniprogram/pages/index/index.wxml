<view class="container">
  <!-- 步骤指示 -->
  <view class="step-indicator">
    <view class="step-dot {{step >= 1 ? 'active' : ''}} {{step > 1 ? 'done' : ''}}">1</view>
    <view class="step-line"></view>
    <view class="step-dot {{step >= 2 ? 'active' : ''}} {{step > 2 ? 'done' : ''}}">2</view>
    <view class="step-line"></view>
    <view class="step-dot {{step >= 3 ? 'active' : ''}}">3</view>
  </view>

  <!-- 步骤1：只选范围 -->
  <view class="step-view" wx:if="{{step === 1}}">
    <text class="welcome">欢迎来到地图掷骰子 🎲</text>
    <text class="welcome-sub">今天想去哪里冒险？先选个范围吧</text>
    <view class="area-list">
      <view
        wx:for="{{areaLabels}}"
        wx:key="id"
        class="area-item {{areaIndex === index ? 'selected' : ''}}"
        bindtap="selectArea"
        data-index="{{index}}"
      >
        <text class="area-name">{{item.name}}</text>
      </view>
    </view>
    <button class="step-btn start-btn" bindtap="goStep2">开始冒险</button>
  </view>

  <!-- 步骤2：掷骰子（一步到位） -->
  <view class="step-view" wx:if="{{step === 2}}">
    <text class="welcome">范围已选好 ✨</text>
    <text class="welcome-sub">点击骰子，随机选一个目的地</text>
    <button class="dice-btn-big" loading="{{isRolling}}" disabled="{{isRolling}}" bindtap="rollDice">
      <text class="dice-emoji">🎲</text>
      <text class="dice-text">掷骰子</text>
    </button>
  </view>

  <!-- 步骤3：出任务 -->
  <view class="step-view" wx:if="{{step === 3}}">
    <text class="welcome">今日目的地 🎯</text>
    <text class="dest-addr">{{destAddr}}</text>
    <button class="step-btn primary" bindtap="goTask">查看今日任务</button>
    <view class="step-actions-minor">
      <text class="link" bindtap="openMap">打开地图导航</text>
      <text class="divider">|</text>
      <text class="link" bindtap="redo">换一个</text>
    </view>
  </view>

  <!-- 地图 -->
  <map
    id="map"
    class="map"
    longitude="{{mapLng}}"
    latitude="{{mapLat}}"
    scale="{{mapScale}}"
    markers="{{markers}}"
    show-location="{{true}}"
  />
</view>
